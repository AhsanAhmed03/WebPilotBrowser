<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/bg_primary">

        <!-- ══════════════════════════════════════
             TOP TOOLBAR
             ══════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/toolbarLayout"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:background="@color/bg_secondary"
            android:elevation="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="6dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:alpha="0.4"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Back"
                android:padding="8dp"
                android:src="@drawable/ic_arrow_back"
                android:tint="@color/text_primary" />

            <ImageButton
                android:id="@+id/btnForward"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:alpha="0.4"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Forward"
                android:padding="8dp"
                android:src="@drawable/ic_arrow_forward"
                android:tint="@color/text_primary" />

            <!-- URL bar container -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_marginHorizontal="4dp"
                android:layout_weight="1"
                android:background="@drawable/bg_url_bar"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="10dp">

                <ImageView
                    android:id="@+id/secureIcon"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginEnd="6dp"
                    android:src="@drawable/ic_lock"
                    android:tint="@color/accent_blue" />

                <EditText
                    android:id="@+id/urlBar"
                    style="@style/BrowserEditText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="Search or enter URL"
                    
                    android:imeOptions="actionGo"
                    android:inputType="textUri"
                    android:maxLines="1"
                    android:singleLine="true"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp" />

                <!-- Clear text button -->
                <ImageButton
                    android:id="@+id/btnClearUrl"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Clear"
                    android:src="@drawable/ic_close"
                    android:tint="@color/text_muted"
                    android:visibility="gone" />

            </LinearLayout>

            <ImageButton
                android:id="@+id/btnReload"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Reload"
                android:padding="8dp"
                android:src="@drawable/ic_refresh"
                android:tint="@color/text_primary" />

        </LinearLayout>

        <!-- Progress Bar -->
        <ProgressBar
            android:id="@+id/progressBar"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="0dp"
            android:layout_height="3dp"
            android:max="100"
            android:progress="0"
            android:progressTint="@color/accent_blue"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/toolbarLayout" />

        <!-- ══════════════════════════════════════
             SEARCH SUGGESTIONS DROPDOWN
             (sits over webview, below toolbar)
             ══════════════════════════════════════ -->
        <androidx.cardview.widget.CardView
            android:id="@+id/suggestionCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="8dp"
            android:layout_marginTop="2dp"
            android:elevation="16dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/bg_secondary"
            app:cardCornerRadius="12dp"
            app:cardElevation="12dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/progressBar">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvSuggestions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxHeight="280dp"
                android:nestedScrollingEnabled="false"
                android:paddingVertical="4dp"
                android:clipToPadding="false" />

        </androidx.cardview.widget.CardView>

        <!-- ══════════════════════════════════════
             SWIPE-TO-REFRESH  +  WEBVIEW CONTAINER
             ══════════════════════════════════════ -->
        <com.browser.app.BrowserSwipeRefreshLayout
            android:id="@+id/swipeRefresh"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintBottom_toTopOf="@id/bottomNavBar"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/progressBar">

            <FrameLayout
                android:id="@+id/webViewContainer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/bg_primary">

                <!-- Native XML Home Page overlay -->
                <include
                    android:id="@+id/homePage"
                    layout="@layout/layout_home_page"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:visibility="gone" />

            </FrameLayout>

        </com.browser.app.BrowserSwipeRefreshLayout>

        <!-- ══════════════════════════════════════
             BOTTOM NAV  [Bookmarks][History][HOME][Tabs][Settings]
             ══════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/bottomNavBar"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:background="@color/bg_secondary"
            android:elevation="8dp"
            android:gravity="center"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <!-- Bookmarks -->
            <LinearLayout
                android:id="@+id/btnBookmarks"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingVertical="8dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_bookmark_filled"
                    android:tint="@color/text_secondary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="Bookmarks"
                    android:textColor="@color/text_secondary"
                    android:textSize="9sp" />

            </LinearLayout>

            <!-- History -->
            <LinearLayout
                android:id="@+id/btnHistory"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingVertical="8dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_history"
                    android:tint="@color/text_secondary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="History"
                    android:textColor="@color/text_secondary"
                    android:textSize="9sp" />

            </LinearLayout>

            <!-- HOME FAB (centre) -->
            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1.1">

                <LinearLayout
                    android:id="@+id/btnHome"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_home_fab"
                    android:elevation="6dp"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_home"
                        android:tint="@color/bg_primary" />

                </LinearLayout>

            </FrameLayout>

            <!-- Tabs -->
            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">

                <LinearLayout
                    android:id="@+id/btnTabsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingVertical="8dp">

                    <FrameLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">

                        <ImageView
                            android:id="@+id/btnTabs"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_tabs"
                            android:tint="@color/text_secondary" />

                        <TextView
                            android:id="@+id/tabCountBadge"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_gravity="top|end"
                            android:layout_marginStart="12dp"
                            android:background="@drawable/bg_tab_badge"
                            android:gravity="center"
                            android:text="1"
                            android:textColor="#FFFFFF"
                            android:textSize="8sp"
                            android:textStyle="bold" />

                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:text="Tabs"
                        android:textColor="@color/text_secondary"
                        android:textSize="9sp" />

                </LinearLayout>

            </FrameLayout>

            <!-- Settings (⋮) -->
            <LinearLayout
                android:id="@+id/btnSettings"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingVertical="8dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_more_vert"
                    android:tint="@color/text_secondary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="Settings"
                    android:textColor="@color/text_secondary"
                    android:textSize="9sp" />

            </LinearLayout>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
