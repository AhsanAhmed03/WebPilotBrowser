<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="accent_blue">#58A6FF</color>
    <color name="accent_green">#3FB950</color>
    <color name="accent_orange">#F0883E</color>
    <color name="accent_purple">#A371F7</color>
    <color name="accent_red">#FF6B6B</color>
    <color name="bg_border">#30363D</color>
    <color name="bg_primary">#0D1117</color>
    <color name="bg_secondary">#161B22</color>
    <color name="bg_tertiary">#21262D</color>
    <color name="colorAccent">#238636</color>
    <color name="colorPrimary">#58A6FF</color>
    <color name="colorPrimaryDark">#0D1117</color>
    <color name="text_muted">#484F58</color>
    <color name="text_primary">#C9D1D9</color>
    <color name="text_secondary">#8B949E</color>
    <string name="app_name">WebPilot Browser</string>
    <string name="back">Back</string>
    <string name="bookmarks">Bookmarks</string>
    <string name="cancel">Cancel</string>
    <string name="clear_all">Clear All</string>
    <string name="close">Close</string>
    <string name="forward">Forward</string>
    <string name="history">History</string>
    <string name="home">Home</string>
    <string name="menu">Menu</string>
    <string name="new_tab">New Tab</string>
    <string name="no_bookmarks">No bookmarks yet.\nBookmark pages from the menu.</string>
    <string name="no_history">No browsing history yet.</string>
    <string name="reload">Reload</string>
    <string name="search_hint">Search or enter URL</string>
    <string name="settings">Settings</string>
    <string name="tabs">Tabs</string>
    <style name="AppTheme" parent="Theme.AppCompat.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="android:statusBarColor">@color/bg_secondary</item>
        <item name="android:navigationBarColor">@color/bg_secondary</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
    <style name="BottomSheetModalStyle" parent="Widget.Design.BottomSheet.Modal">
        <item name="android:background">@drawable/bg_bottom_sheet</item>
    </style>
    <style name="BottomSheetStyle" parent="Theme.Design.Light.BottomSheetDialog">
        <item name="android:windowIsFloating">false</item>
        <item name="bottomSheetStyle">@style/BottomSheetModalStyle</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
    </style>
    <style name="BrowserEditText" parent="Widget.AppCompat.EditText">
        <item name="android:textColorHint">@color/text_muted</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:background">@null</item>
    </style>
    <style name="DialogStyle" parent="Theme.AppCompat.Dialog.Alert">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:background">@android:color/transparent</item>
        <item name="colorAccent">@color/accent_blue</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
    </style>
    <style name="SwitchStyle" parent="Widget.AppCompat.CompoundButton.Switch">
        <item name="colorControlActivated">@color/accent_blue</item>
    </style>
</resources>